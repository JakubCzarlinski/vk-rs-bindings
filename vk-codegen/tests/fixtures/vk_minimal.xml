            <member><type>char</type>           <n>deviceName</n>[<enum>VK_MAX_PHYSICAL_DEVICE_NAME_SIZE</enum>]</member>
            <member><type>uint8_t</type>        <n>pipelineUUID</n>[<enum>VK_UUID_SIZE</enum>]</member>
