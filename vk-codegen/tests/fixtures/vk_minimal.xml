        <type category="union" name="VkClearColorValue">
            <member><type>float</type>   <n>float32</n>[<enum>4</enum>]</member>
            <member><type>int32_t</type> <n>int32</n>[<enum>4</enum>]</member>
            <member><type>uint32_t</type><n>uint32</n>[<enum>4</enum>]</member>
        </type>

